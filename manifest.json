{
  "manifest_version": 3,
  "name": "VPN Awake",
  "version": "1.0.0",
  "description": "Keep the configured internal URL awake while Chrome is running.",
  "permissions": [
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "http://10.21.31.9:8095/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "VPN Awake",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  }
}
